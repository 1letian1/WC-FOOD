DOMAIN=api.example.com
APP_VERSION=latest
SPRING_PROFILES_ACTIVE=prod
DEFAULT_SHOP_ID=1
DB_HOST=mysql
DB_PORT=3306
DB_NAME=shike_ordering
DB_USERNAME=shike
DB_PASSWORD=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_root_password
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
USER_SESSION_TTL=7d
MERCHANT_SESSION_TTL=12h
WECHAT_APP_ID=change_me_wechat_app_id
WECHAT_APP_SECRET=change_me_wechat_app_secret
WECHAT_MOCK_ENABLED=false
UPLOAD_PATH=/app/uploads
PUBLIC_FILE_BASE_URL=https://api.example.com/files
CORS_ALLOWED_ORIGINS=
SWAGGER_ENABLED=false
LOG_LEVEL_ROOT=INFO
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
