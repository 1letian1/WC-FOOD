<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shike.ordering.mapper.SystemConfigMapper">
    <resultMap id="SystemConfigMap" type="com.shike.ordering.entity.SystemConfig">
        <id property="id" column="id"/>
        <result property="configKey" column="config_key"/>
        <result property="configValue" column="config_value"/>
        <result property="description" column="description"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>
    <!-- 复杂查询示范：显式列、参数化条件和明确结果映射。 -->
    <select id="selectByKeyword" resultMap="SystemConfigMap">
        SELECT sc.id, sc.config_key, sc.config_value, sc.description, sc.deleted, sc.version,
               sc.create_time, sc.update_time
        FROM system_config sc
        WHERE sc.deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (sc.config_key LIKE CONCAT('%', #{keyword}, '%')
                 OR sc.description LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY sc.update_time DESC
    </select>
</mapper>
